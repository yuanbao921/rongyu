/* ============================================================
   layout.css — 整体框架布局
   状态栏 / 页面容器 / 底部 Dock
   ============================================================ */

/* ---------- 外层容器 ---------- */
#app {
  height: 100dvh;
  display: flex;
  flex-direction: column;
}

/* ---------- 顶部状态栏 ---------- */
#status-bar {
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 24px 10px;
  padding-top: calc(12px + env(safe-area-inset-top, 0px));
  background: var(--glass);
  backdrop-filter: blur(28px) saturate(1.8) brightness(1.04);
  -webkit-backdrop-filter: blur(28px) saturate(1.8) brightness(1.04);
  border-bottom: 1px solid var(--glass-border);
  font-size: 13px;
  letter-spacing: 0.3px;
  flex-shrink: 0;
}

#status-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

#status-time {
  font-weight: 600;
  color: var(--brown);
  font-size: 15px;
  letter-spacing: 0.5px;
}

#status-date {
  color: var(--brown-mute);
  font-size: 11px;
  letter-spacing: 0.2px;
}

#status-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* 电池图标 */
.batt-ring {
  width: 18px;
  height: 10px;
  border: 1.5px solid var(--brown-light);
  border-radius: 3px;
  position: relative;
  padding: 1.5px;
}
.batt-ring::after {
  content: '';
  position: absolute;
  top: 1.5px; left: 1.5px; right: 1.5px; bottom: 1.5px;
  background: var(--brown-light);
  border-radius: 1.5px;
  width: 70%;
}
.batt-ring::before {
  content: '';
  position: absolute;
  right: -3.5px;
  top: 2px;
  width: 2.5px;
  height: 4px;
  background: var(--brown-light);
  border-radius: 0 1px 1px 0;
}

/* ---------- 页面容器（侧滑基础层）---------- */
#pages {
  flex: 1;
  position: relative;
  overflow: hidden;
}

/* 所有页面绝对叠放，由 JS 控制侧滑 */
.page {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  padding: 14px 16px 10px;
  -webkit-overflow-scrolling: touch;
  /* 默认在右侧屏外待命 */
  transform: translateX(100%);
  opacity: 0;
  pointer-events: none;
  /* 丝滑缓动，退场稍快 */
  transition:
    transform 0.42s var(--ease-out),
    opacity   0.35s var(--ease-smooth);
  will-change: transform, opacity;
}
.page.active {
  transform: translateX(0);
  opacity: 1;
  pointer-events: auto;
}
/* 正在离场的页面向左滑出 */
.page.leaving {
  transform: translateX(-30%);
  opacity: 0;
  pointer-events: none;
}

.page::-webkit-scrollbar { width: 0; }

/* ---------- iPhone 风格 Dock ---------- */
#dock {
  flex-shrink: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  /* 上方留出浮动感间距 */
  margin: 6px 14px calc(10px + env(safe-area-inset-bottom, 0px));
  padding: 10px 8px 10px;
  background: var(--glass);
  backdrop-filter: blur(32px) saturate(2) brightness(1.06);
  -webkit-backdrop-filter: blur(32px) saturate(2) brightness(1.06);
  border-radius: var(--radius-dock);
  border: 1px solid var(--glass-border);
  box-shadow: var(--shadow-dock);
}

.dock-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 6px 4px 4px;
  cursor: pointer;
  color: var(--brown-mute);
  border: none;
  background: transparent;
  border-radius: 16px;
  max-width: 76px;
  transition:
    transform  0.2s var(--ease-spring),
    color      0.2s var(--ease-smooth);
}
.dock-item.active { color: var(--rose); }
.dock-item:active { transform: scale(0.82); }

/* Dock 图标底座（iOS 风格圆角方块）*/
.di-icon-wrap {
  width: 46px;
  height: 46px;
  border-radius: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  background: rgba(255, 248, 243, 0.50);
  border: 1px solid var(--card-border);
  box-shadow: 0 2px 10px rgba(100, 60, 50, 0.08);
  transition:
    background    0.2s var(--ease-smooth),
    box-shadow    0.2s var(--ease-smooth),
    border-color  0.2s;
}
.dock-item.active .di-icon-wrap {
  background: var(--rose-xlight);
  border-color: var(--rose-light);
  box-shadow: 0 2px 16px rgba(194, 130, 122, 0.25);
}

.dock-item .di-label {
  font-size: 9px;
  letter-spacing: 0.4px;
  font-weight: 500;
}

/* ---------- 三条杠菜单按钮 ---------- */
#menu-btn {
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px 2px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  justify-content: center;
  align-items: center;
  width: 28px;
  height: 28px;
  border-radius: 8px;
  transition: background 0.18s;
}
#menu-btn:active { background: var(--rose-xlight); }
#menu-btn span {
  display: block;
  width: 18px;
  height: 1.5px;
  background: var(--brown-light);
  border-radius: 2px;
  transition: all 0.2s var(--ease-smooth);
}
