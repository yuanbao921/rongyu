/* ============================================================
   style.css — 设计令牌 & 全局重置（壁纸兼容版）
   ============================================================ */

/* ---------- 默认主题：玫瑰奶茶 ---------- */
:root {
  --rose:         #C2827A;
  --rose-light:   #DEB0AC;
  --rose-dark:    #A06860;
  --rose-xlight:  rgba(194,130,122,0.12);
  --rose-dim:     rgba(194,130,122,0.22);

  --bg:           #F5EDE4;
  --bg-mid:       #EFE6DC;

  --card:         rgba(255, 252, 248, 0.78);
  --card-border:  rgba(194,130,122,0.15);
  --card-border-hi: rgba(194,130,122,0.28);

  --glass:        rgba(245, 237, 228, 0.78);
  --glass-border: rgba(194,130,122,0.12);

  --brown:        #4A3832;
  --brown-light:  #7A6258;
  --brown-mute:   #B09890;

  --shadow:       0 4px 20px rgba(120,80,70,0.07);
  --shadow-hover: 0 8px 32px rgba(120,80,70,0.12);

  --radius-card:  20px;
  --radius-btn:   14px;
  --radius-input: 12px;
  --radius-dock:  28px;

  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-out:    cubic-bezier(0, 0, 0.2, 1);

  /* ---------- 新增：壁纸用背景变量 ---------- */
  --app-bg: var(--bg);
}

/* ---------- 主题：天空蓝 ---------- */
[data-theme="blue"] {
  --rose:        #7A9EC8;
  --rose-light:  #AACAE0;
  --rose-dark:   #5A7EA8;
  --rose-xlight: rgba(122,158,200,0.12);
  --rose-dim:    rgba(122,158,200,0.22);
  --bg:          #EDF2F8;
  --bg-mid:      #E4EBF3;
  --card:        rgba(240,246,252,0.78);
  --card-border: rgba(122,158,200,0.15);
  --card-border-hi: rgba(122,158,200,0.28);
  --glass:       rgba(237,242,248,0.78);
  --glass-border: rgba(122,158,200,0.12);
  --brown:       #2A3848;
  --brown-light: #5A6878;
  --brown-mute:  #9AAABB;
}

/* ---------- 主题：抹茶绿 ---------- */
[data-theme="green"] {
  --rose:        #7AAA88;
  --rose-light:  #AACAB5;
  --rose-dark:   #5A8A68;
  --rose-xlight: rgba(122,170,136,0.12);
  --rose-dim:    rgba(122,170,136,0.22);
  --bg:          #EDF5EF;
  --bg-mid:      #E4EEE7;
  --card:        rgba(240,248,242,0.78);
  --card-border: rgba(122,170,136,0.15);
  --card-border-hi: rgba(122,170,136,0.28);
  --glass:       rgba(237,245,239,0.78);
  --glass-border: rgba(122,170,136,0.12);
  --brown:       #283832;
  --brown-light: #587868;
  --brown-mute:  #98B0A0;
}

/* ---------- 主题：棕糖 ---------- */
[data-theme="brown"] {
  --rose:        #B89A80;
  --rose-light:  #D0BAA0;
  --rose-dark:   #987860;
  --rose-xlight: rgba(184,154,128,0.12);
  --rose-dim:    rgba(184,154,128,0.22);
  --bg:          #F5EEE6;
  --bg-mid:      #EDE4D8;
  --card:        rgba(252,248,242,0.78);
  --card-border: rgba(184,154,128,0.15);
  --card-border-hi: rgba(184,154,128,0.28);
  --glass:       rgba(245,238,230,0.78);
  --glass-border: rgba(184,154,128,0.12);
  --brown:       #3C2E22;
  --brown-light: #6C5E52;
  --brown-mute:  #A89888;
}

/* ---------- 主题：薰衣草紫 ---------- */
[data-theme="purple"] {
  --rose:        #A080C0;
  --rose-light:  #C0A8D8;
  --rose-dark:   #8060A0;
  --rose-xlight: rgba(160,128,192,0.12);
  --rose-dim:    rgba(160,128,192,0.22);
  --bg:          #F2EDF8;
  --bg-mid:      #EAE4F0;
  --card:        rgba(248,244,252,0.78);
  --card-border: rgba(160,128,192,0.15);
  --card-border-hi: rgba(160,128,192,0.28);
  --glass:       rgba(242,237,248,0.78);
  --glass-border: rgba(160,128,192,0.12);
  --brown:       #382848;
  --brown-light: #685878;
  --brown-mute:  #A898B8;
}

/* ---------- 主题：金秋 ---------- */
[data-theme="gold"] {
  --rose:        #C8A060;
  --rose-light:  #DEC090;
  --rose-dark:   #A88040;
  --rose-xlight: rgba(200,160,96,0.12);
  --rose-dim:    rgba(200,160,96,0.22);
  --bg:          #F8F0E4;
  --bg-mid:      #F0E8D8;
  --card:        rgba(252,248,240,0.78);
  --card-border: rgba(200,160,96,0.15);
  --card-border-hi: rgba(200,160,96,0.28);
  --glass:       rgba(248,240,228,0.78);
  --glass-border: rgba(200,160,96,0.12);
  --brown:       #3C3020;
  --brown-light: #6C6050;
  --brown-mute:  #A89880;
}

/* ---------- 全局重置 ---------- */
*, *::before, *::after {
  margin: 0; padding: 0;
  box-sizing: border-box;
}

/* ---------- body：壁纸/主题色的承载层 ---------- */
body {
  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', 'Helvetica Neue', sans-serif;
  background: var(--bg);
  color: var(--brown);
  height: 100dvh;
  overflow: hidden;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
  transition: background 0.4s ease, color 0.4s ease;
}

/* ---------- #app：占满全屏，背景透明 ---------- */
#app {
  height: 100dvh;
  display: flex;
  flex-direction: column;
  background: transparent;  /* ← 关键：透明，露出 body 的壁纸/主题色 */
  overflow: hidden;
}

/* ---------- 所有页面默认透明，露出壁纸 ---------- */
.page {
  display: none;
  flex: 1;
  flex-direction: column;
  background: transparent;  /* ← 关键：透明 */
  overflow-y: auto;
  padding: 0 16px 8px;
}

.page.active {
  display: flex;
}

/* ---------- 首页：透明，露出壁纸 ---------- */
#page-home {
  padding: 0;
  flex-direction: column;
  overflow: hidden;
  background: transparent;  /* ← 关键：透明，露出壁纸 */
}

/* ---------- 卡片：半透明毛玻璃，透出壁纸 ---------- */
.card {
  background: var(--card);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--card-border);
  border-radius: var(--radius-card);
  padding: 16px 18px;
  margin-bottom: 10px;
  box-shadow: var(--shadow);
  transition: transform 0.2s var(--ease-spring), box-shadow 0.3s, background 0.4s, border-color 0.4s;
}
.card:active { transform: scale(0.97); }

.empty-state {
  color: var(--brown-mute);
  text-align: center;
  padding: 30px 0;
  font-size: 13px;
  line-height: 1.8;
}