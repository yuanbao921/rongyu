/* ============================================================
   components.css — 各功能组件样式
   ============================================================ */

/* ========== 首页 ========== */
#page-home { padding-top: 10px; }

.home-greeting {
  font-size: 22px;
  font-weight: 500;
  letter-spacing: 0.8px;
  margin-bottom: 3px;
  color: var(--brown);
}
.home-sub {
  font-size: 13px;
  color: var(--brown-mute);
  margin-bottom: 16px;
  letter-spacing: 0.3px;
}

/* -- 天气卡片 -- */
.weather-card {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 18px 22px;
}
.weather-icon { font-size: 38px; line-height: 1; flex-shrink: 0; }
.weather-info { flex: 1; }
.weather-temp { font-size: 28px; font-weight: 300; letter-spacing: -0.5px; }
.weather-desc { font-size: 13px; color: var(--brown-light); margin-top: 2px; }
.weather-city { font-size: 11px; color: var(--brown-mute); margin-top: 3px; letter-spacing: 0.3px; }

/* -- 心语卡片 -- */
.quote-card  { text-align: center; padding: 24px 20px 18px; cursor: pointer; }
.quote-text  { font-size: 15px; line-height: 2; color: var(--brown); font-weight: 300; letter-spacing: 0.6px; }
.quote-source { font-size: 12px; color: var(--brown-mute); margin-top: 8px; }
.quote-hint  { font-size: 10px; color: var(--rose); margin-top: 10px; letter-spacing: 1px; opacity: 0.7; }

/* -- 心情选择器 -- */
.mood-card  { padding: 16px 18px; }
.mood-title { font-size: 12px; color: var(--brown-mute); letter-spacing: 1.5px; margin-bottom: 12px; }
.mood-grid  { display: flex; gap: 8px; flex-wrap: wrap; }
.mood-item {
  padding: 7px 15px;
  border-radius: 40px;
  font-size: 13px;
  font-weight: 400;
  border: 1.5px solid var(--rose-light);
  background: transparent;
  color: var(--brown-light);
  cursor: pointer;
  transition: all 0.22s var(--ease-smooth);
  flex-shrink: 0;
  letter-spacing: 0.3px;
}
.mood-item:active { transform: scale(0.93); }
.mood-item.selected {
  background: var(--rose-light);
  color: var(--brown);
  border-color: var(--rose);
}

/* -- 推送 -- */
.push-card  { padding: 14px 18px; }
.push-title { font-size: 12px; color: var(--brown-mute); letter-spacing: 1.5px; margin-bottom: 10px; }
.push-list  { display: flex; flex-direction: column; gap: 2px; }
.push-item  {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid var(--card-border);
}
.push-item:last-child { border-bottom: none; }
.push-icon  { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.push-text  { font-size: 12px; color: var(--brown-light); flex: 1; line-height: 1.6; }
.push-time  { font-size: 10px; color: var(--brown-mute); flex-shrink: 0; margin-top: 2px; }

/* ========== 信号图标 ========== */
.status-signal {
  font-size: 11px;
  color: var(--brown-mute);
  letter-spacing: 1px;
}

/* ========== 便签页 ========== */
#page-notes { padding: 10px 14px; }

.notes-header {
  font-size: 15px;
  font-weight: 500;
  letter-spacing: 1px;
  margin-bottom: 12px;
  color: var(--brown);
  flex-shrink: 0;
}
.notes-scroll {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 12px;
}
.notes-scroll::-webkit-scrollbar { width: 0; }

/* 便签纸 */
.note-paper {
  background: rgba(255, 252, 245, 0.82);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(210, 185, 165, 0.28);
  border-radius: 20px;
  padding: 14px 16px;
  position: relative;
  box-shadow: 0 3px 16px rgba(150, 110, 90, 0.07);
  transition: transform 0.18s var(--ease-spring);
}
.note-paper:active { transform: scale(0.975); }

.note-time { font-size: 10px; color: var(--brown-mute); margin-bottom: 6px; letter-spacing: 0.5px; }
.note-text { font-size: 13px; color: var(--brown); line-height: 1.75; white-space: pre-wrap; }

.note-reply {
  margin-top: 10px;
  padding: 8px 12px;
  background: var(--rose-xlight);
  border-radius: 12px;
  border-left: 2.5px solid var(--rose-light);
  font-size: 12px;
  color: var(--brown-light);
  line-height: 1.6;
}
.note-reply-label {
  font-size: 10px;
  color: var(--rose-dark);
  letter-spacing: 1px;
  margin-bottom: 3px;
}
.note-del {
  margin-top: 8px;
  background: transparent;
  border: 1px solid var(--card-border);
  color: var(--brown-mute);
  border-radius: 8px;
  padding: 3px 10px;
  font-size: 11px;
  cursor: pointer;
  transition: all 0.18s;
}
.note-del:active { background: var(--rose-xlight); color: var(--rose-dark); }

#note-area {
  flex-shrink: 0;
  display: flex;
  gap: 8px;
  border-top: 1px solid var(--card-border);
  padding-top: 10px;
}
#note-inp {
  flex: 1;
  border: 1.5px solid var(--card-border);
  border-radius: var(--radius-input);
  padding: 10px 14px;
  font-size: 13px;
  resize: none;
  outline: none;
  min-height: 44px;
  background: var(--card);
  color: var(--brown);
  font-family: inherit;
  transition: border-color 0.2s;
}
#note-inp::placeholder { color: var(--brown-mute); }
#note-inp:focus { border-color: var(--rose-light); }
#note-btn {
  background: var(--rose-light);
  color: var(--brown);
  border: none;
  border-radius: var(--radius-input);
  padding: 8px 16px;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.18s var(--ease-spring);
}
#note-btn:active { transform: scale(0.92); background: var(--rose); }

/* ========== 聊天页 ========== */
#page-chat { padding: 10px 12px; }

#chat-msgs {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 4px 0;
}
#chat-msgs::-webkit-scrollbar { width: 0; }

.chat-row { display: flex; align-items: flex-end; gap: 8px; }
.chat-row.user { flex-direction: row-reverse; }

.chat-av {
  width: 28px; height: 28px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  border: 1.5px solid var(--card-border);
  flex-shrink: 0;
}
.chat-av.bear  { background: var(--rose-xlight); }
.chat-av.bunny { background: rgba(240, 225, 215, 0.6); }

.chat-bub {
  max-width: 72%;
  padding: 10px 14px;
  border-radius: 18px;
  font-size: 13px;
  line-height: 1.75;
  color: var(--brown);
  white-space: pre-wrap;
  word-break: break-word;
}
.chat-bub.ai {
  background: var(--card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--card-border);
  border-bottom-left-radius: 5px;
  box-shadow: var(--shadow);
}
.chat-bub.user {
  background: var(--rose-light);
  border-bottom-right-radius: 5px;
}
.chat-bub.sys {
  background: transparent;
  color: var(--brown-mute);
  font-size: 11px;
  text-align: center;
  max-width: 100%;
  padding: 2px 0;
  letter-spacing: 0.5px;
}
.chat-bub.think { color: var(--brown-mute); font-style: italic; }

.play-mini {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  margin-top: 5px;
  background: var(--rose-xlight);
  color: var(--rose-dark);
  border: 1px solid var(--rose-light);
  border-radius: 8px;
  padding: 3px 9px;
  font-size: 10px;
  cursor: pointer;
  transition: all 0.18s;
}
.play-mini:active { background: var(--rose-light); }
.play-mini:disabled { opacity: 0.45; cursor: not-allowed; }

#chat-foot {
  display: flex;
  gap: 8px;
  align-items: flex-end;
  padding-top: 10px;
  border-top: 1px solid var(--card-border);
  flex-shrink: 0;
}
#chat-inp {
  flex: 1;
  border: 1.5px solid var(--card-border);
  border-radius: 20px;
  padding: 9px 14px;
  font-size: 13px;
  resize: none;
  outline: none;
  max-height: 80px;
  background: var(--card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  color: var(--brown);
  font-family: inherit;
  transition: border-color 0.2s;
}
#chat-inp::placeholder { color: var(--brown-mute); }
#chat-inp:focus { border-color: var(--rose-light); }
#chat-send {
  background: var(--rose-light);
  color: var(--brown);
  border: none;
  border-radius: 50%;
  width: 36px; height: 36px;
  font-size: 15px;
  cursor: pointer;
  flex-shrink: 0;
  transition: all 0.18s var(--ease-spring);
}
#chat-send:disabled { background: var(--card-border); color: var(--brown-mute); cursor: not-allowed; }
#chat-send:active { transform: scale(0.88); background: var(--rose); }

/* ========== 设置弹窗 ========== */
#settings-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(80, 50, 40, 0.25);
  align-items: flex-end;        /* 从底部弹出，更像 iOS */
  justify-content: center;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}
#settings-overlay.show { display: flex; }

#settings-box {
  background: var(--glass);
  backdrop-filter: blur(32px) saturate(1.8);
  -webkit-backdrop-filter: blur(32px) saturate(1.8);
  border: 1px solid var(--glass-border);
  border-radius: 28px 28px 0 0;
  padding: 12px 22px calc(24px + env(safe-area-inset-bottom, 0px));
  width: 100%;
  max-height: 82vh;
  overflow-y: auto;
  box-shadow: 0 -8px 40px rgba(100, 60, 50, 0.12);
}
#settings-box::-webkit-scrollbar { width: 0; }

/* 拖拽把手 */
#settings-box::before {
  content: '';
  display: block;
  width: 36px;
  height: 4px;
  background: var(--card-border-hi);
  border-radius: 2px;
  margin: 0 auto 18px;
}

#settings-box h2 {
  font-size: 16px;
  font-weight: 500;
  letter-spacing: 2px;
  text-align: center;
  margin-bottom: 18px;
  color: var(--brown);
}

.set-label {
  font-size: 11px;
  color: var(--brown-mute);
  margin-top: 16px;
  margin-bottom: 5px;
  letter-spacing: 1px;
}
.set-label:first-of-type { margin-top: 0; }

.set-inp, .set-txt {
  width: 100%;
  background: rgba(255, 252, 248, 0.6);
  border: 1.5px solid var(--card-border);
  border-radius: var(--radius-input);
  color: var(--brown);
  padding: 10px 14px;
  font-size: 13px;
  outline: none;
  resize: vertical;
  font-family: inherit;
  transition: border-color 0.2s;
}
.set-inp:focus, .set-txt:focus { border-color: var(--rose-light); }
.set-txt { min-height: 64px; }

/* 壁纸选择区 */
.wallpaper-row {
  display: flex;
  gap: 8px;
  margin-top: 2px;
}
.wp-btn {
  flex: 1;
  padding: 9px 0;
  border-radius: var(--radius-input);
  font-size: 12px;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all 0.18s var(--ease-spring);
  background: var(--rose-xlight);
  color: var(--brown);
  border: 1px solid var(--rose-light);
}
.wp-btn:active { transform: scale(0.94); background: var(--rose-light); }
.wp-clear { background: rgba(255,252,248,0.5); border-color: var(--card-border); }

.wp-preview-wrap {
  margin-top: 8px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.wp-preview {
  width: 54px;
  height: 36px;
  border-radius: 8px;
  border: 1px solid var(--card-border);
  background: var(--card-border);
  background-size: cover;
  background-position: center;
  flex-shrink: 0;
}
.wp-hint {
  font-size: 11px;
  color: var(--brown-mute);
  letter-spacing: 0.5px;
}

.set-row {
  display: flex;
  gap: 10px;
  margin-top: 20px;
}
.set-row button {
  flex: 1;
  border-radius: var(--radius-btn);
  padding: 12px 0;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  border: none;
  transition: all 0.18s var(--ease-spring);
}
#set-save  { background: var(--rose-light); color: var(--brown); }
#set-save:active  { transform: scale(0.95); background: var(--rose); }
#set-close { background: rgba(255,252,248,0.5); color: var(--brown-mute); border: 1px solid var(--card-border) !important; }
#set-close:active { transform: scale(0.95); }


/* ========== 专注页 ========== */
#page-focus {
  padding: 14px 16px 10px;
  overflow-y: auto;
  align-items: stretch;
}

/* -- 番茄钟计时器 -- */
.focus-timer-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 8px 0 16px;
  flex-shrink: 0;
}

/* SVG 进度环 */
.focus-ring-svg {
  width: 180px;
  height: 180px;
  transform: rotate(-90deg);
  flex-shrink: 0;
}
.focus-ring-bg {
  fill: none;
  stroke: var(--card-border);
  stroke-width: 6;
}
.focus-ring-progress {
  fill: none;
  stroke: var(--rose);
  stroke-width: 6;
  stroke-linecap: round;
  stroke-dasharray: 276.46;
  stroke-dashoffset: 0;
  transition: stroke-dashoffset 0.9s var(--ease-smooth);
  filter: drop-shadow(0 0 6px rgba(194, 130, 122, 0.5));
}

/* 环中间的时间 */
.focus-ring-inner {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  inset: 0;
}
.focus-ring-container {
  position: relative;
  width: 180px;
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
}
#focus-time-display {
  font-size: 38px;
  font-weight: 300;
  letter-spacing: 2px;
  color: var(--brown);
  line-height: 1;
}
#focus-phase-label {
  font-size: 11px;
  color: var(--brown-mute);
  margin-top: 5px;
  letter-spacing: 1.5px;
}

/* 开始按钮 */
#focus-start-btn {
  margin-top: 16px;
  background: var(--rose-light);
  color: var(--brown);
  border: none;
  border-radius: var(--radius-btn);
  padding: 12px 36px;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  letter-spacing: 0.5px;
  transition: all 0.2s var(--ease-spring);
  box-shadow: 0 4px 16px rgba(194, 130, 122, 0.25);
}
#focus-start-btn:active { transform: scale(0.92); background: var(--rose); }

/* 今日番茄数 */
#focus-session-count {
  font-size: 11px;
  color: var(--brown-mute);
  margin-top: 8px;
  letter-spacing: 0.5px;
}

/* -- AI 感受气泡 -- */
.ai-comment-card {
  margin: 0 0 14px;
  background: var(--card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--card-border);
  border-radius: var(--radius-card);
  padding: 14px 18px;
  box-shadow: var(--shadow);
  flex-shrink: 0;
}
.ai-comment-label {
  font-size: 10px;
  color: var(--rose);
  letter-spacing: 1.5px;
  margin-bottom: 6px;
}
#ai-comment {
  font-size: 13px;
  color: var(--brown);
  line-height: 1.75;
  font-weight: 300;
  min-height: 20px;
  transition: opacity 0.3s;
}
#ai-comment.fade-in {
  animation: quoteFade 0.4s var(--ease-out) both;
}

/* -- 频道选择 -- */
.channel-section {
  flex-shrink: 0;
  margin-bottom: 12px;
}
.channel-label {
  font-size: 10px;
  color: var(--brown-mute);
  letter-spacing: 1.5px;
  margin-bottom: 8px;
}
#channel-row {
  display: flex;
  gap: 8px;
}
.channel-btn {
  flex: 1;
  padding: 8px 4px;
  border-radius: var(--radius-input);
  font-size: 12px;
  border: 1.5px solid var(--card-border);
  background: var(--card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  color: var(--brown-light);
  cursor: pointer;
  transition: all 0.2s var(--ease-smooth);
  font-family: inherit;
  letter-spacing: 0.3px;
}
.channel-btn:active  { transform: scale(0.93); }
.channel-btn.active  {
  background: var(--rose-xlight);
  border-color: var(--rose-light);
  color: var(--brown);
  box-shadow: 0 2px 12px rgba(194,130,122,0.2);
}

/* -- 播放器 -- */
.music-player-card {
  margin-bottom: 8px;
  background: var(--card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--card-border);
  border-radius: var(--radius-card);
  padding: 14px 16px;
  box-shadow: var(--shadow);
  flex-shrink: 0;
}
.music-now-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}
#track-art {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  background: var(--rose-xlight);
  border: 1px solid var(--card-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
  background-size: cover;
  background-position: center;
  transition: transform 0.3s;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
#track-art.spinning {
  animation: spin 8s linear infinite;
  border-radius: 50%;
}
.music-info { flex: 1; min-width: 0; }
#track-name {
  font-size: 13px;
  color: var(--brown);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
#track-artist {
  font-size: 11px;
  color: var(--brown-mute);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.music-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
}
.music-controls button {
  background: transparent;
  border: none;
  font-size: 20px;
  cursor: pointer;
  color: var(--brown-light);
  padding: 4px 8px;
  transition: all 0.18s var(--ease-spring);
  border-radius: 8px;
}
.music-controls button:active { transform: scale(0.85); color: var(--rose); }
#music-play-btn {
  font-size: 26px !important;
  color: var(--rose) !important;
  background: var(--rose-xlight) !important;
  border-radius: 50% !important;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--rose-light) !important;
}

/* ============================================================
   专注页 · 番茄钟 + 音乐
   ============================================================ */

#page-focus {
  padding: 12px 14px;
  gap: 14px;
}

/* ---------- 番茄钟环 ---------- */
.focus-timer-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.focus-ring-container {
  position: relative;
  width: 160px;
  height: 160px;
}

.focus-ring-svg {
  width: 160px;
  height: 160px;
  transform: rotate(-90deg);
}

.focus-ring-bg {
  fill: none;
  stroke: var(--card-border);
  stroke-width: 6;
}

.focus-ring-progress {
  fill: none;
  stroke: var(--rose);
  stroke-width: 6;
  stroke-linecap: round;
  transition: stroke-dashoffset 1s linear;
  /* dasharray 由 JS 写入 */
}

.focus-ring-inner {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

#focus-time-display {
  font-size: 32px;
  font-weight: 300;
  letter-spacing: 1px;
  color: var(--brown);
  font-variant-numeric: tabular-nums;
}

#focus-phase-label {
  font-size: 11px;
  color: var(--brown-mute);
  letter-spacing: 1.5px;
}

#focus-session-count {
  font-size: 11px;
  color: var(--brown-mute);
  letter-spacing: 0.5px;
}

/* ---------- AI 感受气泡 ---------- */
.ai-comment-card {
  background: var(--card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--card-border);
  border-radius: 20px;
  padding: 14px 16px;
  display: flex;
  gap: 10px;
  align-items: flex-start;
  box-shadow: var(--shadow);
  flex-shrink: 0;
}

.ai-comment-label {
  font-size: 16px;
  flex-shrink: 0;
  margin-top: 1px;
}

#ai-comment {
  font-size: 13px;
  color: var(--brown-light);
  line-height: 1.75;
  flex: 1;
  letter-spacing: 0.3px;
}

/* ---------- 频道选择 ---------- */
.channel-section { flex-shrink: 0; }

.channel-label {
  font-size: 11px;
  color: var(--brown-mute);
  letter-spacing: 1.5px;
  margin-bottom: 8px;
}

#channel-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.channel-chip {
  padding: 7px 14px;
  border-radius: 40px;
  font-size: 12px;
  border: 1.5px solid var(--card-border);
  background: var(--card);
  color: var(--brown-light);
  cursor: pointer;
  transition: all 0.2s var(--ease-smooth);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  white-space: nowrap;
}
.channel-chip:active { transform: scale(0.94); }
.channel-chip.active {
  background: var(--rose-xlight);
  border-color: var(--rose-light);
  color: var(--rose-dark);
}

/* ---------- 播放器卡片 ---------- */
.music-player-card {
  background: var(--card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--card-border);
  border-radius: var(--radius-card);
  padding: 16px 18px;
  box-shadow: var(--shadow);
  flex-shrink: 0;
}

.music-now-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}

#track-art {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: var(--rose-xlight);
  border: 1px solid var(--card-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
  transition: transform 0.3s var(--ease-smooth);
}
#track-art.spinning {
  animation: spin360 8s linear infinite;
}
@keyframes spin360 {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.music-info { flex: 1; min-width: 0; }
#track-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--brown);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
#track-artist {
  font-size: 11px;
  color: var(--brown-mute);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 进度条 */
.music-progress-wrap {
  height: 3px;
  background: var(--card-border);
  border-radius: 2px;
  margin-bottom: 14px;
  overflow: hidden;
}
.music-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--rose-light), var(--rose));
  border-radius: 2px;
  width: 0%;
  transition: width 0.8s linear;
}

.music-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
}

#music-prev-btn, #music-next-btn {
  background: transparent;
  border: none;
  font-size: 18px;
  cursor: pointer;
  color: var(--brown-mute);
  padding: 4px 8px;
  transition: all 0.18s var(--ease-spring);
}
#music-prev-btn:active, #music-next-btn:active {
  transform: scale(0.88);
  color: var(--rose);
}

#music-play-btn {
  width: 46px; height: 46px;
  border-radius: 50%;
  background: var(--rose-light);
  border: none;
  font-size: 18px;
  cursor: pointer;
  color: var(--brown);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(194, 130, 122, 0.3);
  transition: all 0.2s var(--ease-spring);
}
#music-play-btn:active { transform: scale(0.88); background: var(--rose); }

/* ---------- 操控按钮 ---------- */
.focus-actions {
  display: flex;
  gap: 10px;
  flex-shrink: 0;
}

#focus-start-btn {
  flex: 1;
  padding: 13px 0;
  border-radius: var(--radius-btn);
  border: none;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  letter-spacing: 0.5px;
  background: var(--rose-light);
  color: var(--brown);
  transition: all 0.2s var(--ease-spring);
  box-shadow: 0 4px 20px rgba(194, 130, 122, 0.25);
}
#focus-start-btn:active { transform: scale(0.96); background: var(--rose); }
#focus-start-btn.running {
  background: rgba(210, 180, 165, 0.3);
  color: var(--brown-mute);
  box-shadow: none;
}

/* ============================================================
   开屏页
   ============================================================ */
#splash {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 237, 228, 0.82);
  backdrop-filter: blur(32px) saturate(1.8);
  -webkit-backdrop-filter: blur(32px) saturate(1.8);
  transition: opacity 0.8s ease, visibility 0.8s ease;
}
#splash.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.splash-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.splash-avatars {
  display: flex;
  align-items: center;
  gap: -12px;
}

.splash-av {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: rgba(255, 248, 243, 0.9);
  border: 3px solid rgba(200, 170, 160, 0.3);
  box-shadow: 0 8px 32px rgba(150, 100, 80, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44px;
  overflow: hidden;
  transition: transform 0.3s var(--ease-spring);
}
.splash-av:first-child {
  transform: translateX(12px);
  z-index: 2;
}
.splash-av:last-child {
  transform: translateX(-12px);
  z-index: 1;
}
.splash-av img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

.splash-title {
  font-size: 28px;
  font-weight: 300;
  letter-spacing: 8px;
  color: var(--brown);
}
.splash-sub {
  font-size: 13px;
  color: var(--brown-mute);
  letter-spacing: 3px;
}

/* 头像上传区 */
.avatar-upload-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
}
.avatar-preview {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--rose-xlight);
  border: 1px solid var(--card-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  overflow: hidden;
  flex-shrink: 0;
}
.avatar-preview img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}
