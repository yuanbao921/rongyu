<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>🍉 合成大绒球 · 陆沉</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;
      background: var(--bg, #F5EDE4);
      height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      transition: background 0.4s;
    }

    .game-wrapper {
      width: 96%;
      max-width: 420px;
      background: rgba(255, 252, 248, 0.45);
      backdrop-filter: blur(28px) saturate(1.4);
      -webkit-backdrop-filter: blur(28px) saturate(1.4);
      border-radius: 32px;
      padding: 16px 16px 20px;
      border: 1px solid rgba(194, 130, 122, 0.06);
      box-shadow: 0 8px 48px rgba(90, 74, 58, 0.04);
      text-align: center;
    }

    .game-title {
      font-size: 13px;
      color: rgba(90, 74, 58, 0.22);
      letter-spacing: 6px;
      margin-bottom: 10px;
      font-weight: 300;
    }

    canvas {
      display: block;
      width: 100%;
      aspect-ratio: 1 / 1.4;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 18px;
      border: 1px solid rgba(194, 130, 122, 0.04);
      touch-action: none;
      cursor: pointer;
      box-shadow: inset 0 2px 20px rgba(90, 74, 58, 0.02);
    }

    .game-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 12px;
      padding: 0 4px;
    }

    .score {
      font-size: 14px;
      color: var(--brown, #4A3832);
      font-weight: 400;
      letter-spacing: 0.5px;
    }
    .score span {
      font-weight: 300;
      color: var(--rose, #C2827A);
    }

    .message-box {
      flex: 1;
      text-align: right;
      font-size: 12px;
      color: var(--rose, #C2827A);
      font-weight: 350;
      letter-spacing: 0.3px;
      min-height: 1.5em;
      font-style: italic;
      padding-left: 8px;
    }

    .btn-group {
      display: flex;
      gap: 10px;
      justify-content: center;
      margin-top: 12px;
    }

    .btn {
      padding: 8px 22px;
      border-radius: 40px;
      border: 1px solid rgba(194, 130, 122, 0.10);
      background: rgba(255, 255, 255, 0.20);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      font-size: 12px;
      color: var(--brown, #4A3832);
      cursor: pointer;
      transition: all 0.18s;
      font-family: inherit;
      letter-spacing: 0.5px;
    }
    .btn:active {
      transform: scale(0.92);
      background: rgba(194, 130, 122, 0.06);
    }

    .btn-primary {
      background: var(--rose, #C2827A);
      color: #fff;
      border-color: var(--rose, #C2827A);
    }
    .btn-primary:active {
      background: var(--rose-dark, #A06860);
    }

    .back-link {
      display: inline-block;
      margin-top: 10px;
      font-size: 11px;
      color: rgba(90, 74, 58, 0.15);
      text-decoration: none;
      letter-spacing: 1px;
      border-bottom: 1px solid rgba(194, 130, 122, 0.03);
      padding-bottom: 2px;
    }
    .back-link:active {
      color: rgba(90, 74, 58, 0.30);
    }

    @media (max-width: 400px) {
      .game-wrapper { padding: 12px 10px 16px; }
      .score { font-size: 12px; }
      .message-box { font-size: 11px; }
      .btn { font-size: 11px; padding: 6px 16px; }
    }
  </style>
</head>
<body>

<div class="game-wrapper">
  <div class="game-title">✦ 合 成 大 绒 球 ✦</div>

  <canvas id="gameCanvas" width="400" height="560"></canvas>

  <div class="game-info">
    <div class="score">🌟 <span id="scoreDisplay">0</span></div>
    <div class="message-box" id="messageBox">点上方放小爱心</div>
  </div>

  <div class="btn-group">
    <button class="btn" id="restartBtn">🔄 重来</button>
    <button class="btn btn-primary" id="nextBtn">下一个 💕</button>
  </div>

  <a class="back-link" href="index.html">← 回 绒 语</a>
</div>

<script>
  // ============================================================
  //  合成大绒球 · 陆沉版
  //  水果链：💕 → ✨ → 🌙 → ☀️ → 🌸 → 🍑 → 大绒球
  // ============================================================

  const canvas = document.getElementById('gameCanvas');
  const ctx = canvas.getContext('2d');
  const scoreDisplay = document.getElementById('scoreDisplay');
  const messageBox = document.getElementById('messageBox');

  // ---------- 尺寸 ----------
  const W = canvas.width;
  const H = canvas.height;
  const COLS = 6;
  const GAP = 6;
  const RADIUS = 28;
  const DROP_Y = 60;

  // ---------- 水果链 ----------
  const FRUITS = [
    { emoji: '💕', value: 1, color: '#E88080' },
    { emoji: '✨', value: 2, color: '#F0C060' },
    { emoji: '🌙', value: 4, color: '#C0B0D0' },
    { emoji: '☀️', value: 8, color: '#F0A030' },
    { emoji: '🌸', value: 16, color: '#E8A0B0' },
    { emoji: '🍑', value: 32, color: '#F0A080' },
    { emoji: '🧶', value: 64, color: '#D4A0C0' }, // 大绒球
  ];

  // ---------- 陆沉语录 ----------
  const LUCHEN_SAYS = {
    2: '✨ 小星星亮了，像你的眼睛。',
    4: '🌙 月亮出来了，我在想你。',
    8: '☀️ 太阳升起来了，你起床了吗？',
    16: '🌸 花开了一朵，像你的笑。',
    32: '🍑 桃子熟了，你尝一口吗？',
    64: '🧶 大绒球！我的心被你装满了。',
  };

  // ---------- 状态 ----------
  let grid = [];
  let currentFruit = 0;
  let nextFruit = 0;
  let dropX = 2;
  let score = 0;
  let gameOver = false;
  let canDrop = true;
  let isDropping = false;

  // ---------- 初始化 ----------
  function initGame() {
    grid = [];
    for (let row = 0; row < 12; row++) {
      grid[row] = [];
      for (let col = 0; col < COLS; col++) {
        grid[row][col] = null;
      }
    }
    currentFruit = Math.floor(Math.random() * 3);
    nextFruit = Math.floor(Math.random() * 3);
    dropX = Math.floor(COLS / 2);
    score = 0;
    gameOver = false;
    canDrop = true;
    isDropping = false;
    scoreDisplay.textContent = '0';
    messageBox.textContent = '点上方放小爱心 💕';
    draw();
  }

  // ---------- 获取水果颜色 ----------
  function getFruitColor(index) {
    return FRUITS[index] ? FRUITS[index].color : '#E88080';
  }

  function getFruitEmoji(index) {
    return FRUITS[index] ? FRUITS[index].emoji : '💕';
  }

  // ---------- 查找下落位置 ----------
  function findDropRow(col) {
    for (let row = grid.length - 1; row >= 0; row--) {
      if (!grid[row][col]) return row;
    }
    return -1;
  }

  // ---------- 检测碰撞合并 ----------
  function checkMerge(row, col) {
    const val = grid[row][col];
    if (val === null || val >= FRUITS.length - 1) return false;

    let merged = false;
    const neighbors = [
      [row - 1, col], [row + 1, col],
      [row, col - 1], [row, col + 1],
      [row - 1, col - 1], [row - 1, col + 1],
      [row + 1, col - 1], [row + 1, col + 1]
    ];

    for (const [nr, nc] of neighbors) {
      if (nr < 0 || nr >= grid.length || nc < 0 || nc >= COLS) continue;
      if (grid[nr][nc] === val) {
        // 合并！
        grid[nr][nc] = null;
        grid[row][col] = val + 1;
        merged = true;

        // 加分
        const addScore = Math.pow(2, val + 1);
        score += addScore;
        scoreDisplay.textContent = score;

        // 陆沉说话
        const newVal = val + 1;
        const say = LUCHEN_SAYS[newVal] || `合成了 ${FRUITS[newVal].emoji}！`;
        messageBox.textContent = '✨ ' + say;

        // 如果合成大绒球
        if (newVal === FRUITS.length - 1) {
          messageBox.textContent = '🧶 大绒球！陆沉说：我的心都是你的了。';
        }

        // 递归检查新合成
        checkMerge(row, col);
        return true;
      }
    }
    return merged;
  }

  // ---------- 掉落 ----------
  function dropFruit() {
    if (gameOver || !canDrop || isDropping) return;

    const row = findDropRow(dropX);
    if (row === -1) {
      gameOver = true;
      messageBox.textContent = '💔 装不下了… 陆沉说：没关系，我陪你重来。';
      draw();
      return;
    }

    isDropping = true;
    grid[row][dropX] = currentFruit;

    // 检查合并
    checkMerge(row, dropX);

    // 准备下一个水果
    currentFruit = nextFruit;
    nextFruit = Math.floor(Math.random() * 3);
    dropX = Math.floor(COLS / 2);
    canDrop = true;
    isDropping = false;

    // 检查游戏结束
    if (grid[0][Math.floor(COLS / 2)] !== null) {
      gameOver = true;
      messageBox.textContent = '💔 堆满了… 陆沉说：我陪你重新开始。';
    }

    draw();
  }

  // ---------- 绘制 ----------
  function draw() {
    ctx.clearRect(0, 0, W, H);

    // 毛玻璃网格
    ctx.strokeStyle = 'rgba(194, 130, 122, 0.04)';
    ctx.lineWidth = 0.5;
    const cellW = W / COLS;
    const cellH = H / grid.length;
    for (let i = 0; i <= COLS; i++) {
      ctx.beginPath();
      ctx.moveTo(i * cellW, 0);
      ctx.lineTo(i * cellW, H);
      ctx.stroke();
    }
    for (let i = 0; i <= grid.length; i++) {
      ctx.beginPath();
      ctx.moveTo(0, i * cellH);
      ctx.lineTo(W, i * cellH);
      ctx.stroke();
    }

    // 绘制已放置的水果
    for (let row = 0; row < grid.length; row++) {
      for (let col = 0; col < COLS; col++) {
        const val = grid[row][col];
        if (val === null) continue;
        const x = col * cellW + cellW / 2;
        const y = row * cellH + cellH / 2;
        const r = Math.min(cellW, cellH) * 0.38;

        // 光晕
        const grad = ctx.createRadialGradient(x - r * 0.2, y - r * 0.2, 0, x, y, r);
        grad.addColorStop(0, 'rgba(255,255,255,0.2)');
        grad.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();

        // 水果 emoji（大号）
        ctx.font = `${r * 1.2}px "Segoe UI Emoji", "Apple Color Emoji", sans-serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(getFruitEmoji(val), x, y + 1);

        // 边框光晕
        ctx.shadowColor = 'rgba(194, 130, 122, 0.03)';
        ctx.shadowBlur = 8;
        ctx.shadowBlur = 0;
      }
    }

    // 绘制当前待掉落水果（顶部）
    if (!gameOver && currentFruit !== null) {
      const x = dropX * cellW + cellW / 2;
      const y = DROP_Y;
      const r = Math.min(cellW, cellH) * 0.40;
      ctx.font = `${r * 1.3}px "Segoe UI Emoji", "Apple Color Emoji", sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(getFruitEmoji(currentFruit), x, y + 1);

      // 指示器（虚线）
      ctx.setLineDash([4, 6]);
      ctx.strokeStyle = 'rgba(194, 130, 122, 0.10)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x, DROP_Y + r + 8);
      ctx.lineTo(x, DROP_Y + r + 40);
      ctx.stroke();
      ctx.setLineDash([]);

      // 下一个水果预览
      ctx.font = '16px "Segoe UI Emoji", "Apple Color Emoji", sans-serif';
      ctx.textAlign = 'right';
      ctx.textBaseline = 'bottom';
      ctx.fillText('下一个 ' + getFruitEmoji(nextFruit), W - 10, DROP_Y + 30);
    }

    // 游戏结束遮罩
    if (gameOver) {
      ctx.fillStyle = 'rgba(90, 74, 58, 0.08)';
      ctx.fillRect(0, 0, W, H);
      ctx.font = '22px "Segoe UI Emoji", "Apple Color Emoji", sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('💔 重来吧', W / 2, H / 2 - 10);
      ctx.font = '12px "PingFang SC", sans-serif';
      ctx.fillStyle = 'rgba(90, 74, 58, 0.30)';
      ctx.fillText('点「重来」继续', W / 2, H / 2 + 30);
    }
  }

  // ---------- 移动指示器 ----------
  function moveDrop(dx) {
    if (gameOver || isDropping) return;
    const newX = dropX + dx;
    if (newX >= 0 && newX < COLS) {
      dropX = newX;
      draw();
    }
  }

  // ---------- 事件绑定 ----------
  // 键盘
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') moveDrop(-1);
    if (e.key === 'ArrowRight') moveDrop(1);
    if (e.key === 'ArrowDown' || e.key === ' ') {
      e.preventDefault();
      dropFruit();
    }
  });

  // 触摸/点击 canvas
  let touchX = null;
  canvas.addEventListener('touchstart', (e) => {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    const touch = e.touches[0];
    const canvasX = (touch.clientX - rect.left) * scaleX;
    const canvasY = (touch.clientY - rect.top) * scaleY;

    if (canvasY < 80) {
      // 点击顶部 → 放下
      dropFruit();
    } else {
      // 左右滑动移动
      touchX = canvasX;
    }
  }, { passive: true });

  canvas.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (touchX === null) return;
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const touch = e.touches[0];
    const canvasX = (touch.clientX - rect.left) * scaleX;
    const dx = canvasX - touchX;
    if (Math.abs(dx) > 20) {
      moveDrop(dx > 0 ? 1 : -1);
      touchX = canvasX;
    }
  }, { passive: false });

  canvas.addEventListener('touchend', () => {
    touchX = null;
  }, { passive: true });

  // 鼠标点击
  canvas.addEventListener('click', (e) => {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    const canvasX = (e.clientX - rect.left) * scaleX;
    const canvasY = (e.clientY - rect.top) * scaleY;

    if (canvasY < 80) {
      dropFruit();
    } else {
      // 点击左右两侧移动
      if (canvasX < W / 3) moveDrop(-1);
      else if (canvasX > W * 2 / 3) moveDrop(1);
      else dropFruit();
    }
  });

  // 按钮：下一个（手动触发掉落）
  document.getElementById('nextBtn').addEventListener('click', dropFruit);

  // 重来
  document.getElementById('restartBtn').addEventListener('click', () => {
    initGame();
  });

  // ---------- 启动 ----------
  initGame();
</script>

</body>
</html>